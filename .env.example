# GRC Toolkit Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────
# Production: use sslmode=require for encryption in transit
GRC_DATABASE_URL=postgresql+psycopg2://grc:CHANGE_ME@db:5432/grc_toolkit?sslmode=require
POSTGRES_DB=grc_toolkit
POSTGRES_USER=grc
POSTGRES_PASSWORD=CHANGE_ME

# ── API Security ──────────────────────────────────────────────────────
# Comma-separated API keys. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
GRC_API_KEYS=

# CORS allowed origins (comma-separated)
GRC_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
GRC_RATE_LIMIT_RPM=120
GRC_RATE_LIMIT_BURST=20

# Disable Swagger docs in production
GRC_ENABLE_DOCS=false

# ── OPA ───────────────────────────────────────────────────────────────
GRC_OPA_URL=http://opa:8181

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME

# ── Notifications (optional) ─────────────────────────────────────────
GRC_SLACK_WEBHOOK_URL=
GRC_SMTP_SERVER=
GRC_SMTP_PORT=587
GRC_SMTP_SENDER=
GRC_SMTP_PASSWORD=

# ── Cloud Providers ──────────────────────────────────────────────────
# AWS: uses default credential chain (env vars, ~/.aws/credentials, IAM role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Azure
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=

# GCP
# GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Lambda/Serverless ────────────────────────────────────────────────
GRC_S3_BUCKET=grc-toolkit-evidence
GRC_ORGANIZATION=Your Organization
GRC_SYSTEM_NAME=Primary System
