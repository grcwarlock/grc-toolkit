{
  "servers": [
    {
      "name": "GRC Toolkit API (Development)",
      "type": "uvicorn",
      "command": "uvicorn api.main:app --reload --host 127.0.0.1 --port 8000",
      "env": {},
      "port": 8000,
      "url": "http://127.0.0.1:8000",
      "docs_url": "http://127.0.0.1:8000/docs",
      "description": "FastAPI dev server with auto-reload"
    },
    {
      "name": "GRC Toolkit API (Replit)",
      "type": "uvicorn",
      "command": "uvicorn api.main:app --host 0.0.0.0 --port 8000",
      "env": {},
      "port": 8000,
      "url": "http://0.0.0.0:8000",
      "docs_url": "http://0.0.0.0:8000/docs",
      "description": "FastAPI server for Replit deployment (no reload, binds all interfaces)"
    }
  ]
}
