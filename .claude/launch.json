{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "docs-preview",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "9090", "--directory", "docs"],
      "port": 9090
    },
    {
      "name": "grc-api",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["api.main:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    }
  ]
}
